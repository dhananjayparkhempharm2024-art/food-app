{
  "info": {
    "name": "FoodExpress Admin APIs",
    "_postman_id": "b9f4f07f-cd0a-4f58-8eb9-2e849f65ab4b",
    "description": "Admin panel APIs: Order History, Coupons, Reviews, and System Settings.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "couponId",
      "value": "1"
    },
    {
      "key": "reviewId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get Order History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/orders/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "orders",
                "history"
              ]
            },
            "description": "Returns all orders wrapped as { \"data\": [...] }."
          }
        }
      ]
    },
    {
      "name": "Coupons",
      "item": [
        {
          "name": "Get Coupons",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/coupons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "coupons"
              ]
            }
          }
        },
        {
          "name": "Create Coupon",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"save20\",\n  \"discountType\": \"PERCENTAGE\",\n  \"discountValue\": 20,\n  \"minOrderAmount\": 200,\n  \"expiryDate\": \"2026-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/coupons",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "coupons"
              ]
            },
            "description": "Code is normalized to uppercase by backend."
          }
        },
        {
          "name": "Delete Coupon",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/coupons/{{couponId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "coupons",
                "{{couponId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/reviews",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "reviews"
              ]
            }
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/reviews/{{reviewId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "reviews",
                "{{reviewId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "System Settings",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/settings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "settings"
              ]
            }
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"siteName\": \"FoodExpress\",\n  \"maintenanceMode\": false,\n  \"baseDeliveryFee\": 35,\n  \"adminEmail\": \"admin@foodexpress.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/settings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "settings"
              ]
            }
          }
        }
      ]
    }
  ]
}

